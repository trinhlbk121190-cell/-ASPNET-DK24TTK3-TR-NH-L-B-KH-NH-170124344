@{
    Layout = "_Layout";
    ViewBag.Title = "Đăng nhập - MedForum";
}
<div class="auth-page">
    <div class="auth-visual">
        <div class="auth-visual-content">
            <div class="brand-icon large"><i class="fas fa-heartbeat"></i></div>
            <h2>Chào mừng trở lại!</h2>
            <p>Đăng nhập để đặt câu hỏi, nhận tư vấn từ bác sĩ và tham gia cộng đồng y tế.</p>
            <div class="auth-features">
                <div class="af-item"><i class="fas fa-shield-alt"></i> Bảo mật tuyệt đối</div>
                <div class="af-item"><i class="fas fa-user-md"></i> Bác sĩ xác thực</div>
                <div class="af-item"><i class="fas fa-user-secret"></i> Hỗ trợ ẩn danh</div>
            </div>
        </div>
    </div>
    <div class="auth-form-panel">
        <div class="auth-form-card">
            <div class="auth-logo"><i class="fas fa-heartbeat"></i></div>
            <h1>Đăng nhập</h1>
            <p class="auth-subtitle">Tiếp tục với tài khoản MedForum của bạn</p>

            <form asp-controller="Auth" asp-action="Login" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                <div class="form-group">
                    <label><i class="fas fa-envelope"></i> Email</label>
                    <input type="email" name="email" placeholder="your@email.com" required class="form-control" />
                </div>
                <div class="form-group">
                    <label><i class="fas fa-lock"></i> Mật khẩu</label>
                    <div class="password-field">
                        <input type="password" name="password" id="loginPassword" placeholder="••••••••" required class="form-control" />
                        <button type="button" onclick="togglePassword('loginPassword')" class="pw-toggle"><i class="fas fa-eye"></i></button>
                    </div>
                </div>
                <div class="form-options-row">
                    <label class="remember-me">
                        <input type="checkbox" name="rememberMe" value="true" /> Ghi nhớ đăng nhập
                    </label>
                </div>
                <button type="submit" class="btn-auth-submit"><i class="fas fa-sign-in-alt"></i> Đăng nhập</button>
            </form>

            <div class="demo-accounts">
                <p><i class="fas fa-info-circle"></i> Tài khoản demo:</p>
                <div class="demo-grid">
                    <button class="demo-btn" onclick="fillDemo('admin@medicalforum.com','Admin@12345')"><i class="fas fa-shield-alt"></i> Admin</button>
                    <button class="demo-btn" onclick="fillDemo('bsnguyenvana@medicalforum.com','Doctor@12345')"><i class="fas fa-user-md"></i> Bác sĩ</button>
                    <button class="demo-btn" onclick="fillDemo('benhnhan1@medicalforum.com','Patient@12345')"><i class="fas fa-user"></i> Bệnh nhân</button>
                </div>
            </div>

            <p class="auth-switch">Chưa có tài khoản? <a asp-controller="Auth" asp-action="Register">Đăng ký ngay</a></p>
        </div>
    </div>
</div>
@section Scripts {
<script>
    function fillDemo(email, pw) {
        document.querySelector('[name="email"]').value = email;
        document.querySelector('[name="password"]').value = pw;
    }
    function togglePassword(id) {
        const inp = document.getElementById(id);
        inp.type = inp.type === 'password' ? 'text' : 'password';
    }
</script>
}
