@{
    Layout = "_Layout";
    ViewBag.Title = "Đăng ký - MedForum";
}
<div class="auth-page">
    <div class="auth-visual register">
        <div class="auth-visual-content">
            <div class="brand-icon large"><i class="fas fa-heartbeat"></i></div>
            <h2>Tham gia cộng đồng!</h2>
            <p>Hàng nghìn người dùng và bác sĩ đang chia sẻ kiến thức y tế mỗi ngày.</p>
        </div>
    </div>
    <div class="auth-form-panel">
        <div class="auth-form-card">
            <div class="auth-logo"><i class="fas fa-user-plus"></i></div>
            <h1>Tạo tài khoản</h1>
            <p class="auth-subtitle">Miễn phí và chỉ mất 1 phút</p>

            <form asp-controller="Auth" asp-action="Register" method="post">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label><i class="fas fa-user"></i> Họ và tên</label>
                    <input type="text" name="fullName" placeholder="Nguyễn Văn A" required class="form-control" />
                </div>
                <div class="form-group">
                    <label><i class="fas fa-envelope"></i> Email</label>
                    <input type="email" name="email" placeholder="your@email.com" required class="form-control" />
                </div>
                <div class="form-group">
                    <label><i class="fas fa-lock"></i> Mật khẩu</label>
                    <div class="password-field">
                        <input type="password" name="password" id="regPassword" placeholder="Tối thiểu 6 ký tự" required class="form-control" />
                        <button type="button" onclick="togglePassword('regPassword')" class="pw-toggle"><i class="fas fa-eye"></i></button>
                    </div>
                </div>
                <div class="form-group">
                    <label><i class="fas fa-id-badge"></i> Vai trò</label>
                    <div class="role-selector">
                        <label class="role-option selected" onclick="selectRole(this, 'Patient')">
                            <input type="radio" name="role" value="Patient" checked />
                            <i class="fas fa-user"></i>
                            <span>Bệnh nhân</span>
                            <small>Đặt câu hỏi, nhận tư vấn</small>
                        </label>
                        <label class="role-option" onclick="selectRole(this, 'Doctor')">
                            <input type="radio" name="role" value="Doctor" />
                            <i class="fas fa-user-md"></i>
                            <span>Bác sĩ</span>
                            <small>Tư vấn, cần xác minh</small>
                        </label>
                    </div>
                </div>
                <button type="submit" class="btn-auth-submit"><i class="fas fa-user-plus"></i> Đăng ký</button>
            </form>
            <p class="auth-switch">Đã có tài khoản? <a asp-controller="Auth" asp-action="Login">Đăng nhập</a></p>
        </div>
    </div>
</div>
@section Scripts {
<script>
    function selectRole(el, role) {
        document.querySelectorAll('.role-option').forEach(r => r.classList.remove('selected'));
        el.classList.add('selected');
        el.querySelector('input').checked = true;
    }
    function togglePassword(id) {
        const inp = document.getElementById(id);
        inp.type = inp.type === 'password' ? 'text' : 'password';
    }
</script>
}
